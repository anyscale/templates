  "project_name": "anyscale_jobs_intro",
  "template_intent": {
    "purpose": "A practical standalone template for job submission, runtime env layout, retries, logs, and debugging from a clean workspace. Give users one minimal artifact they can clone, submit, fail, debug, and rerun without needing broader course context.",
